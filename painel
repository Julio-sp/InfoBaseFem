<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <title>Painel de Gestão EAC</title>
    <style>
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background: #f4f4f9; padding: 20px; display: flex; justify-content: center; }
        #login-container, #painel-conteudo { background: white; padding: 40px; border-radius: 12px; box-shadow: 0 4px 15px rgba(0,0,0,0.1); width: 100%; max-width: 800px; }
        #painel-conteudo { display: none; }
        .nav-buttons { margin-top: 30px; display: flex; justify-content: space-between; }
        button { padding: 12px 25px; cursor: pointer; background: #2c3e50; color: white; border: none; border-radius: 6px; font-weight: bold; }
        button:hover { background: #34495e; }
        h1, h2 { color: #2c3e50; }
        input { padding: 10px; width: 200px; border: 1px solid #ccc; border-radius: 4px; }
    </style>
</head>
<body>

    <div id="login-container">
        <h1>Acesso EAC</h1>
        <p>Insira a senha para acessar os dados protegidos:</p>
        <input type="password" id="senha" placeholder="Senha">
        <button onclick="verificarAcesso()">Entrar</button>
    </div>

    <div id="painel-conteudo">
        <h2 id="titulo-pergunta">Carregando...</h2>
        <div id="exibicao-pergunta" style="margin-top: 20px;"></div>
        <div class="nav-buttons">
            <button onclick="mudarPergunta(-1)">Anterior</button>
            <button onclick="mudarPergunta(1)">Próximo</button>
        </div>
    </div>

    <script>
        let dados = [];
        let indiceAtual = 0;
        // Colunas de texto conforme solicitado
        const colunasTexto = ['G','M','R','W','AB','AF','AG','AM','AN','AO'];

        function verificarAcesso() {
            if(document.getElementById('senha').value === 'EAC2026') {
                document.getElementById('login-container').style.display = 'none';
                document.getElementById('painel-conteudo').style.display = 'block';
                buscarDados();
            } else { alert('Senha incorreta!'); }
        }

        async function buscarDados() {
            const url = 'https://docs.google.com/spreadsheets/d/e/2PACX-1vTYPGCKAs-MiM-pofVu5bUqA-S_SA16ndk6muHYap6PdWsZ00VICpHEdTQgqgbALTqFaAsaVb_3GQya/pub?output=csv';
            try {
                const res = await fetch(url);
                const texto = await res.text();
                const linhas = texto.split('\n');
                const titulos = linhas[0].split(',');
                
                // Mapeia colunas de B em diante (pula coluna A)
                dados = titulos.slice(1).map((t, i) => {
                    let letraColuna = String.fromCharCode(66 + i);
                    return {
                        titulo: t.replace(/"/g, ''), // Limpa aspas do CSV
                        ehTexto: colunasTexto.includes(letraColuna)
                    };
                });
                renderizar();
            } catch (e) {
                document.getElementById('titulo-pergunta').innerText = "Erro ao carregar dados.";
            }
        }

        function renderizar() {
            const p = dados[indiceAtual];
            document.getElementById('titulo-pergunta').innerText = p.titulo;
            document.getElementById('exibicao-pergunta').innerHTML = p.ehTexto ? 
                "<em>Este campo exibe respostas descritivas das atletas.</em>" : 
                "<em>Este campo exibe o gráfico de classificação (1-5 estrelas).</em>";
        }

        function mudarPergunta(dir) {
            indiceAtual = Math.max(0, Math.min(dados.length - 1, indiceAtual + dir));
            renderizar();
        }
    </script>
</body>
</html>
